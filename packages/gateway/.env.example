# Agent Arcade Gateway — Environment Variables
# Copy to .env and adjust for your deployment.

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8787

# ── Persistence & Horizontal Scale ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_ADAPTER=1
RETENTION_SECONDS=86400
MAX_EVENTS=500
REPLAY_COUNT=50

# ── Security ──────────────────────────────────────────────────────────────────
REQUIRE_AUTH=1
JWT_SECRET=replace-with-strong-random-secret
SESSION_SIGNING_SECRET=replace-with-different-strong-random-secret

# API_KEYS format: keyId:keyValue:role:sessionRegex,keyId2:keyValue:role:sessionRegex
# role ∈ viewer|publisher|admin
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Strict comma-separated allowlist. Do not use * in production.
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Abuse Protection ──────────────────────────────────────────────────────────
RATE_WINDOW_MS=1000
RATE_MAX_IP=120
RATE_MAX_TOKEN=240
SESSION_FLOOD_MAX=600

# ── Internal Routes ───────────────────────────────────────────────────────────
ENABLE_INTERNAL_ROUTES=1
