{
  "name": "@agent-arcade/gateway",
  "version": "3.8.1",
  "description": "Agent Arcade telemetry relay gateway \u00e2\u20ac\u201d WebSocket + SSE + HTTP ingest",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test test/",
    "directive-bridge": "bun src/directive-bridge.ts",
    "multi-agent": "bun src/multi-agent-orchestrator.ts",
    "all-agents": "concurrently \"bun run dev\" \"bun run directive-bridge\" \"bun run multi-agent\""
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "jose": "^6.1.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.4",
    "@types/uuid": "^10.0.0"
  }
}
