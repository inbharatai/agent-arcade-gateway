# Agent Arcade Web — Environment Variables
# Copy to .env.local and adjust for your deployment.

# ── Gateway URL (required for production) ─────────────────────────────────────
# This is baked into the client bundle at build time.
# In dev, if unset, the app auto-detects using the browser hostname + port 8787.
NEXT_PUBLIC_GATEWAY_URL=https://gateway.your-domain.com

# ── Secure Session Token Issuance ─────────────────────────────────────────────
# Server-side only (do not prefix with NEXT_PUBLIC)
GATEWAY_JWT_SECRET=replace-with-the-same-secret-used-by-gateway
SESSION_SIGNING_SECRET=replace-with-the-same-signing-secret-used-by-gateway

# ── Client Session UX ─────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_SESSION_ID=copilot-live
NEXT_PUBLIC_LOCK_SESSION_ID=1
NEXT_PUBLIC_CLIENT_ROLE=viewer
SESSION_TOKEN_TTL_SEC=3600
