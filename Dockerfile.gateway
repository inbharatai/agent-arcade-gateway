# ── Gateway: Bun runtime ─────────────────────────────────────────────────────
FROM oven/bun:1 AS gateway

WORKDIR /app
COPY packages/gateway/package.json ./
RUN bun install --production
COPY packages/gateway/ ./

# Ensure a healthcheck tool is available
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

EXPOSE 8787
ENV PORT=8787
CMD ["bun", "src/index.ts"]
