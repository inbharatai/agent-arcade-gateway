# Agent Arcade — Root Environment Variables
# Copy to .env and adjust for your deployment.
# See packages/gateway/.env.example and packages/web/.env.example for per-package docs.

# Gateway
PORT=8787
ALLOWED_ORIGINS=https://your-domain.com
RATE_WINDOW_MS=1000
RATE_MAX_IP=120
RATE_MAX_TOKEN=240
SESSION_FLOOD_MAX=600
MAX_EVENTS=500
REDIS_URL=redis://localhost:6379
REQUIRE_AUTH=1
JWT_SECRET=replace-with-strong-random-secret
SESSION_SIGNING_SECRET=replace-with-different-strong-random-secret
ENABLE_REDIS_ADAPTER=1
RETENTION_SECONDS=86400

# Web App (baked in at build time)
NEXT_PUBLIC_GATEWAY_URL=https://gateway.your-domain.com
NEXT_PUBLIC_DEFAULT_SESSION_ID=copilot-live
NEXT_PUBLIC_LOCK_SESSION_ID=1

# Web App (server-only)
GATEWAY_JWT_SECRET=replace-with-the-same-secret-used-by-gateway
